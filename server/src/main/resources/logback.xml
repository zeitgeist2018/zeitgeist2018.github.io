<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%date %level [%thread] [%X{trace_id}] %logger{64} %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="es.cristianlm" level="debug"/>
    <logger name="ktor.application" level="warn"/>

    <root level="info">
        <appender-ref ref="STDOUT"/>
    </root>

</configuration>
